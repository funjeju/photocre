      "dedicated_sets": [
        {
          "title": "A Quiet Light",
          "folio": "p. 04",
          "body": "A Quiet Light is a study of the hours before the world is fully awake. The series was photographed over four months in a single coastal town, in available daylight, on medium format film. The intent was not to document, but to slow the looking — to give the morning the attention it usually goes without.",
          "infobox": {
            "Photographer": "Robert William",
            "Series": "A Quiet Light",
            "Year": "2024 · Spring",
            "Format": "Medium format · Mamiya 7",
            "Film": "Kodak Portra 400",
            "Edition": "1 / 25"
          }
        },
        {
          "title": "Surface",
          "folio": "p. 08",
          "body": "Surface is a portfolio of close-range studies: stone, water, paper, skin. The aim was to remove the easy compositional crutches — horizon, subject, narrative — and to ask whether a single texture could carry an image on its own. The series was photographed in a single studio over a calendar year, under a north-facing window.",
          "infobox": {
            "Photographer": "Maya Halden",
            "Series": "Surface",
            "Year": "2024 · Annual",
            "Format": "Digital · Phase One IQ4",
            "Lens": "Schneider 90mm",
            "Edition": "Open"
          }
        },
        {
          "title": "Drift",
          "folio": "p. 12",
          "body": "Drift was photographed from a small wooden boat on a river that had no particular hurry. Twelve days, a single roll of film per day, no rule against repetition. The work that emerged is concerned less with the river itself than with the way attention behaves when there is, for once, very little for it to latch onto.",
          "infobox": {
            "Photographer": "S. Arden",
            "Series": "Drift",
            "Year": "2024 · July",
            "Format": "35mm · Leica M6",
            "Film": "Tri-X 400",
            "Edition": "1 / 18"
          }
        },
        {
          "title": "Hour Blue",
          "folio": "p. 16",
          "body": "Hour Blue is the result of a year-long appointment with one moment. Every night, twenty minutes after sunset, a single frame from a single window. The series is a quiet argument about how much, and how little, a city changes from one evening to the next, and which of those changes the eye is willing to notice.",
          "infobox": {
            "Photographer": "E. Solbakken",
            "Series": "Hour Blue",
            "Year": "2024 · Annual",
            "Format": "Medium format · Fuji GFX",
            "Lens": "63mm f/2.8",
            "Edition": "1 / 12"
          }
        },
        {
          "title": "Salt and Iron",
          "folio": "p. 20",
          "body": "Salt and Iron is a documentary study of a small commercial harbour at the bookends of its working day. Photographed in the half-hour before sunrise and the half-hour after sunset, the work tries to honour the harbour's mechanics without dressing them up in the usual romance of working light.",
          "infobox": {
            "Photographer": "T. Matsura",
            "Series": "Salt and Iron",
            "Year": "2024 · Autumn",
            "Format": "Medium format · Plaubel 67",
            "Film": "Portra 800",
            "Edition": "1 / 22"
          }
        },
        {
          "title": "Slow Glass",
          "folio": "p. 24",
          "body": "Slow Glass is a series of very long exposures, made through old window panes in derelict houses. The film records, over the course of an hour, what the glass has been looking at: the shifting weather outside, the slow wandering of dust, the occasional shadow of a passer-by who never stops to look back.",
          "infobox": {
            "Photographer": "P. Rosen",
            "Series": "Slow Glass",
            "Year": "2024 · Winter",
            "Format": "4×5 · Sinar P2",
            "Lens": "Schneider 150mm",
            "Edition": "1 / 9"
          }
        },
        {
          "title": "Untitled (Garden)",
          "folio": "p. 28",
          "body": "Untitled (Garden) is a long, deliberately uneventful project. One small garden, photographed weekly, for two years. There is no event the work is leading up to. The interest is in the slow accumulation of changes that none of us, individually, would have thought worth photographing.",
          "infobox": {
