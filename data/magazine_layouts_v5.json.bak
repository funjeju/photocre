      "dedicated_sets": [
        {
          "runninghead": "MONOGRAPH NO. 04 · ROBERT WILLIAM · A QUIET LIGHT",
          "eyebrow": "— PLATE 14",
          "title": "A Quiet Light",
          "folio": "p. 22",
          "infobox": {
