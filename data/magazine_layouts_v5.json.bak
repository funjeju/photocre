      "dedicated_sets": [
        {
          "title": "Plates 14 & 15",
          "caption": "Diptych from A QUIET LIGHT, autumn exhibition, north gallery, salt prints.",
          "folio": "p. 04",
          "body": "Plates 14 and 15 were made on consecutive mornings during the fourth and final month of the working period. The two photographs share a single window and a single subject, and the change between them is largely a matter of the previous night's weather. The diptych is hung as a single work in the autumn exhibition, with a centre-line of forty millimetres between the two prints, which is the smallest separation the gallery's mounting system allows.",
          "infobox": {
            "Exhibition": "A Quiet Light",
            "Photographer": "Robert William",
            "Period": "15 Sept — 30 Nov 2024",
            "Curator": "H. Kelder",
            "Gallery": "North Wing",
            "Run": "Editions of 25",
            "Print": "Salt print on cotton",
            "Mount": "Hahnemühle Bamboo"
          }
        },
        {
          "title": "Plates 09 & 10",
          "caption": "Diptych from DRIFT, autumn rotation, east gallery, silver gelatin prints.",
          "folio": "p. 08",
          "body": "Plates 9 and 10 are the working pair from the central week of the twelve-day project. They were made within a single hour, from the same anchored position on the boat, and the two negatives differ in exposure by a third of a stop. The exhibition copy is mounted as a single horizontal piece. The catalogue lists the work under the photographer's preferred sequencing, which places the slightly underexposed frame on the left.",
          "infobox": {
            "Exhibition": "Drift",
            "Photographer": "S. Arden",
            "Period": "1 Oct — 30 Dec 2024",
            "Curator": "K. Halldór",
            "Gallery": "East Wing",
            "Run": "Editions of 18",
            "Print": "Silver gelatin",
            "Mount": "Archival window"
          }
        },
        {
          "title": "Plates 22 & 23",
          "caption": "Companion pair from SURFACE, winter exhibition, south gallery, pigment prints.",
          "folio": "p. 12",
          "body": "Plates 22 and 23 sit at the centre of the SURFACE portfolio. The two studies were made in the same afternoon, on the same wall, with the camera unmoved between exposures. The subject — concrete in raking light — is the same in both frames; only the position of the photographer's hand, between the two exposures, differs. The catalogue copy notes that this is the only pair in the working archive in which the photographer's shadow is, on careful looking, just visible.",
          "infobox": {
            "Exhibition": "Surface",
            "Photographer": "Maya Halden",
            "Period": "7 Jan — 28 Feb 2025",
            "Curator": "A. Brynjolfsson",
            "Gallery": "South Wing",
            "Run": "Open edition",
            "Print": "Pigment on Hahnemühle",
            "Mount": "Standard frame"
          }
        },
        {
          "title": "Plates 218 & 219",
          "caption": "Two consecutive evenings from HOUR BLUE, spring rotation, west gallery, pigment.",
          "folio": "p. 16",
          "body": "Plates 218 and 219 correspond to the second and third of October in the year-long HOUR BLUE project. The two evenings differ principally in atmosphere — the second of October was wet, the third was clear — and the diptych demonstrates the project's central thesis with unusual clarity. The catalogue lists the pair as the most-requested work for private viewing during the autumn run, and the gallery has retained the original prints in its permanent collection.",
          "infobox": {
            "Exhibition": "Hour Blue",
            "Photographer": "E. Solbakken",
            "Period": "1 Mar — 31 May 2025",
            "Curator": "P. Lyngård",
            "Gallery": "West Wing",
            "Run": "Editions of 12",
            "Print": "Pigment on Baryta",
            "Mount": "Float frame"
          }
        },
        {
          "title": "Plates 06 & 07",
          "caption": "Pair from SALT AND IRON, summer exhibition, harbour archive room.",
          "folio": "p. 20",
          "body": "Plates 6 and 7 are the working pair from the eleventh evening of the working period. They were made within twenty minutes of each other, at the half-hour after sunset, and document the same harbour from two adjacent quays. The diptych is exhibited under variable interior lighting, in keeping with the photographer's stated preference, and the print run was tied to the number of working boats in the harbour at the time of the exhibition's opening.",
          "infobox": {
            "Exhibition": "Salt and Iron",
            "Photographer": "T. Matsura",
            "Period": "15 Jun — 15 Aug 2025",
            "Curator": "M. Eikeland",
            "Gallery": "Harbour Room",
            "Run": "Editions of 22",
            "Print": "Silver gelatin",
            "Mount": "Iron-frame"
          }
        },
        {
          "title": "Plates 03 & 04",
          "caption": "Long-exposure pair from SLOW GLASS, winter rotation, archive cabinet.",
          "folio": "p. 24",
          "body": "Plates 3 and 4 of SLOW GLASS were exposed for sixty-two and sixty-eight minutes respectively, through adjacent panes of the same north-facing window. The diptych is, by some margin, the longest single working session in the photographer's archive. The catalogue copy notes that two persons crossed the field beyond the window during the second of the two exposures, and that neither figure is visible in the final print, which is, in the project's working philosophy, the entire point.",
          "infobox": {
            "Exhibition": "Slow Glass",
            "Photographer": "P. Rosen",
            "Period": "1 Dec — 28 Feb",
            "Curator": "R. Kallio",
            "Gallery": "Archive Cabinet",
            "Run": "Editions of 9",
            "Print": "Silver gelatin",
            "Mount": "Custom shadow box"
          }
        },
        {
          "title": "Plates 73 & 74",
          "caption": "Consecutive weekly exposures from UNTITLED (GARDEN), summer rotation, courtyard.",
          "folio": "p. 28",
          "body": "Plates 73 and 74 are weeks seventy-three and seventy-four of the two-year UNTITLED (GARDEN) project. The two photographs were made exactly one week apart, in approximately the same light, and the differences between them are, on a first look, almost invisible. The diptych has been chosen by the curator as the project's representative pairing for the courtyard exhibition, where it is shown alongside a small selection of working notes.",
          "infobox": {
            "Exhibition": "Untitled (Garden)",
            "Photographer": "M. Oyedepo",
            "Period": "1 Jul — 30 Sept",
            "Curator": "O. Adekunle",
            "Gallery": "Courtyard",
            "Run": "Editions of 30",
            "Print": "Pigment on cotton",
            "Mount": "Garden display"
          }
        },
        {
          "title": "Plates 12 & 13",
          "caption": "Two sittings from NORTH LIGHT, spring rotation, portrait room.",
          "folio": "p. 32",
          "body": "Plates 12 and 13 are the twelfth and thirteenth sittings of the sixteen-portrait series. Both sitters were photographed under the same north-facing window, in the same chair, with the same lens and the same exposure, and on consecutive afternoons. The diptych is the only pair in the working archive in which two different sitters, photographed in the same conditions, agreed to be exhibited together. The names are listed only in the catalogue's index.",
          "infobox": {
            "Exhibition": "North Light",
            "Photographer": "J. Akinola",
            "Period": "15 Mar — 15 May",
            "Curator": "L. Mensah",
            "Gallery": "Portrait Room",
            "Run": "Editions of 16",
            "Print": "Silver gelatin",
            "Mount": "Wood frame"
          }
        },
        {
          "title": "Plates 09 & 10",
          "caption": "Two interiors from ARCHITECTURE OF AIR, autumn rotation, west annex.",
          "folio": "p. 36",
          "body": "Plates 9 and 10 are two adjacent rooms in the same building, photographed within forty minutes of one another, both in their unoccupied state. The diptych demonstrates the project's principal thesis — that every well-designed room has a particular shape of air — by showing how differently two adjacent rooms in the same building handle the same hour of light. The exhibition copy is hung in a single mat, with a separation of twelve millimetres between the two prints.",
          "infobox": {
            "Exhibition": "Architecture of Air",
            "Photographer": "V. Atala",
            "Period": "1 Sept — 30 Nov",
            "Curator": "D. Reyna",
            "Gallery": "West Annex",
            "Run": "Editions of 14",
            "Print": "Pigment on Baryta",
            "Mount": "Float frame"
          }
        },
        {
          "title": "Plates 04 & 05",
          "caption": "Two contributions from LAST HOUR, year-end exhibition, group show.",
          "folio": "p. 40",
          "body": "Plates 4 and 5 of LAST HOUR were contributed to the group portfolio by two anonymous photographers working in different European cities. The two frames were made within nine minutes of each other on a Tuesday in early November. The pairing was made by the editor, and the photographers did not learn of the diptych until the catalogue was distributed at the year-end exhibition. The accompanying notes, in both cases, are kept to a single sentence.",
          "infobox": {
            "Exhibition": "Last Hour",
            "Editorial": "Group Show",
            "Period": "15 Dec — 15 Jan",
            "Curator": "The Editorial Group",
            "Gallery": "Year-End Hall",
            "Run": "Editions of 30",
            "Print": "Mixed processes",
            "Mount": "Standard frame"
          }
        }
      ],
