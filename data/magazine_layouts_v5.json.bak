        {
          "eyebrow": "— ON TRAVEL",
          "pullquote": "I travel not to go anywhere, but to go.",
          "byline": "R. L. STEVENSON · 1850–1894",
          "caption": "Cevennes, France, the third week, walking the donkey route.",
          "folio": "p. 30"
        },
        {
          "eyebrow": "— ON TIME",
          "pullquote": "Twenty years from now you will regret what you did not do.",
          "byline": "MARK TWAIN · 1835–1910",
          "caption": "Mississippi River, near Hannibal, late summer evening.",
          "folio": "p. 38"
        },
        {
          "eyebrow": "— ON STILLNESS",
          "pullquote": "Nature does not hurry, yet everything is accomplished.",
          "byline": "LAOZI · 6TH CENTURY BCE",
          "caption": "Old growth pine on the slope above the village.",
          "folio": "p. 46"
        },
        {
          "eyebrow": "— ON SOLITUDE",
          "pullquote": "I never found the companion that was so companionable as solitude.",
          "byline": "H. D. THOREAU · 1817–1862",
          "caption": "Walden cabin, the lamp lit on the table by the window.",
          "folio": "p. 54"
        },
        {
          "eyebrow": "— ON FLOWERS",
          "pullquote": "The earth laughs in flowers.",
          "byline": "R. W. EMERSON · 1803–1882",
          "caption": "Concord meadow, late May, the morning after rain.",
          "folio": "p. 62"
        },
        {
          "eyebrow": "— ON BEAUTY",
          "pullquote": "A thing of beauty is a joy forever.",
          "byline": "JOHN KEATS · 1795–1821",
          "caption": "Lake Como, Italy, evening light on the cypresses.",
          "folio": "p. 70"
        },
        {
          "eyebrow": "— ON RETURN",
          "pullquote": "What we love deeply becomes a part of us.",
          "byline": "G. SANTAYANA · 1863–1952",
          "caption": "Family pasture, first morning back, October.",
          "folio": "p. 78"
        }
      ],
