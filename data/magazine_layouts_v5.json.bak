    {
      "id": "1-04",
      "name": "Cinematic Cover",
      "description": "이미지 풀블리드 + 좌하단에 컬러 액센트 박스 안에 챕터 타이틀 + 본문. 흑백 사진의 임팩트를 살리는 클래식.",
      "imageCount": 1,
      "style": "cinematic_cover",
      "aspectRatio": "4:3",
      "background": "obsidian",
      "images": [
        {
          "x": 0,
          "y": 0,
          "w": 100,
          "h": 100
        }
      ],
      "texts": [
        {
          "type": "eyebrow",
          "x": 6,
