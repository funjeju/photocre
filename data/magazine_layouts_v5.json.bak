      "dedicated_sets": [
        {
          "title": "Karl Vega · Three Series",
          "folio": "p. 04",
          "body": "This triple-portfolio gathers the three published series of Karl Vega: SATURDAY LIGHT (the urban weekend project), BLOCK PARTY (the summer street series), and FIRST FROST (the winter morning sequence). The three series were made over a period of seven years and share, in Vega's own working note, the conviction that the most photogenic hours in any city are, paradoxically, the ones during which the city is least busy. The triple is sequenced by year of completion. Each series is represented by its strongest single frame.",
          "infobox": {
            "Photographer": "Karl Vega",
            "Series 1": "Saturday Light · 2018",
            "Series 2": "Block Party · 2020",
            "Series 3": "First Frost · 2024",
            "Format": "Medium format, 6×7",
            "Edition": "1 / 25 each",
            "Print": "Pigment on Hahnemühle"
          }
        },
        {
          "title": "Asha Mendelssohn · Working Hands",
          "folio": "p. 08",
          "body": "This triple gathers the three published series of Asha Mendelssohn: TWELVE HANDS (artisans), READING (the close study of hands holding books), and PIANO (concert pianists, in the practice room). The three series share a single working hypothesis — that the human hand, photographed at close range, is more legible than the face. Mendelssohn has not yet abandoned the hypothesis, and a fourth series is in preparation. The triple is, by editorial choice, sequenced by chronological order rather than by subject density.",
          "infobox": {
            "Photographer": "Asha Mendelssohn",
            "Series 1": "Twelve Hands · 2019",
            "Series 2": "Reading · 2021",
            "Series 3": "Piano · 2023",
            "Format": "4×5 large format",
            "Edition": "Editions of 18",
            "Print": "Silver gelatin"
          }
        },
        {
          "title": "Ren Fuyuko · Three Routes",
          "folio": "p. 12",
          "body": "This triple presents the three completed routes of Ren Fuyuko's long-running BICYCLE YEAR project: the morning commute (year one), the lunchtime detour (year two), and the evening return (year three). Each route was photographed over a calendar year, with one frame per working day, on the same lens and the same small camera. Fuyuko has, in the working note for this triple, indicated that a fourth route is unlikely. The triple is sequenced by year, with one representative frame from each route.",
          "infobox": {
            "Photographer": "Ren Fuyuko",
            "Route 1": "Morning · 2020",
            "Route 2": "Lunchtime · 2022",
            "Route 3": "Evening · 2024",
            "Format": "Compact 35mm",
            "Edition": "Open / Pigment",
            "Print": "Pigment on Bamboo"
          }
        },
        {
          "title": "Pieter Drost · The Empty Room",
          "folio": "p. 16",
          "body": "This triple gathers Pieter Drost's three room-based portfolios: ROOMS WITH DOORS CLOSED (hotel rooms after checkout), ROOMS WITH DOORS OPEN (workplaces during lunch), and ROOMS WITH NO DOORS (open-plan offices, after hours). The three series share Drost's continuing investigation of how a room behaves when the people for whom it was designed have, briefly, left. The triple is sequenced by year of working start. Each portfolio is represented by the plate Drost considers, in the introductory note, his strongest.",
          "infobox": {
            "Photographer": "Pieter Drost",
            "Series 1": "Doors Closed · 2019",
            "Series 2": "Doors Open · 2021",
            "Series 3": "No Doors · 2023",
            "Format": "Medium format, 6×6",
            "Edition": "Editions of 14",
            "Print": "Silver gelatin"
          }
        },
        {
          "title": "Lou Berner · The Listening Series",
          "folio": "p. 20",
          "body": "This triple gathers Lou Berner's three musician-portrait series: LISTENING HOURS (musicians at home, working), QUIET ROOMS (composers, between commissions), and AFTER THE CONCERT (performers, in the half-hour after a public performance). The three series form, by Berner's own description, a triptych on private musical practice. The triple is sequenced by the public visibility of the working subject — most private first, most public last — which inverts the more usual chronological arrangement.",
          "infobox": {
            "Photographer": "Lou Berner",
            "Series 1": "Listening Hours · 2020",
            "Series 2": "Quiet Rooms · 2022",
            "Series 3": "After the Concert · 2024",
            "Format": "35mm rangefinder",
            "Edition": "Editions of 22",
            "Print": "Silver gelatin"
          }
        },
        {
          "title": "Ines Tarras · Southern Light",
          "folio": "p. 24",
          "body": "This triple presents Ines Tarras's three Iberian portfolios: HEAT WAVE (August in the Spanish south), SIESTA HOUR (the closed afternoon shutters of small towns), and FIRST RAIN (September, when the heat finally breaks). The three series were made in approximately the same five towns, in successive years, and the triple's sequencing is by season rather than by year. Tarras has, in the introductory note, indicated that a fourth series — likely concerning night markets — is under preparation, and may not appear before next summer.",
          "infobox": {
            "Photographer": "Ines Tarras",
            "Series 1": "Heat Wave · 2021",
            "Series 2": "Siesta Hour · 2023",
            "Series 3": "First Rain · 2024",
            "Format": "Medium format, 6×9",
            "Edition": "Editions of 18",
            "Print": "Pigment on cotton"
          }
        },
        {
          "title": "Owen Maramba · Weather Trilogy",
          "folio": "p. 28",
          "body": "This triple gathers Owen Maramba's three weather-monitoring portfolios: FORECAST (the unmanned Hebrides station), READINGS (alpine recording instruments, in winter), and SIGNALS (the radar archives of a coastal harbour). All three series document the meeting of automatic instruments with the weather they record. The triple is sequenced by altitude — sea level, high country, summit — and is, by Maramba's own working description, the closest thing in his archive to a complete career statement.",
          "infobox": {
            "Photographer": "Owen Maramba",
            "Series 1": "Forecast · 2019",
            "Series 2": "Readings · 2022",
            "Series 3": "Signals · 2024",
            "Format": "4×5 large format",
            "Edition": "Editions of 12",
            "Print": "Silver gelatin"
          }
        },
        {
          "title": "Yuna Kjellberg · Long Distance",
          "folio": "p. 32",
          "body": "This triple gathers Yuna Kjellberg's three transit portfolios: SLOW TRAINS (the long-distance Eastern European routes), NIGHT FERRIES (the Baltic crossings, in winter), and OVERNIGHT BUSES (the Greek-Italian schedule, photographed across two summers). The three series share Kjellberg's continuing interest in the behaviour of strangers in temporary, semi-public rooms. The triple is sequenced by the average duration of the working journey, which is also, by coincidence, the order in which the three series were completed.",
          "infobox": {
            "Photographer": "Yuna Kjellberg",
            "Series 1": "Slow Trains · 2020",
            "Series 2": "Night Ferries · 2022",
            "Series 3": "Overnight Buses · 2024",
            "Format": "35mm compact",
            "Edition": "Editions of 25",
            "Print": "Pigment prints"
          }
        },
        {
          "title": "Diego Roso · After Service",
          "folio": "p. 36",
          "body": "This triple presents Diego Roso's three liturgical portfolios: AFTER SERVICE (churches in the half-hour after the morning mass), AFTER MARKET (cathedral squares after the Saturday market), and AFTER FESTIVAL (small-town churches in the days following the patron saint's day). The three series share Roso's interest in the half-empty room, immediately after its public function has concluded. The triple is sequenced by the public scale of the prior gathering — smallest first, largest last — and demonstrates, in the photographer's own working note, the consistency of his framing decisions.",
          "infobox": {
            "Photographer": "Diego Roso",
            "Series 1": "After Service · 2018",
            "Series 2": "After Market · 2021",
            "Series 3": "After Festival · 2024",
            "Format": "Medium format, 6×7",
            "Edition": "Editions of 16",
            "Print": "Silver gelatin"
          }
        },
        {
          "title": "Hannah Ott · The Self-Portrait Project",
          "folio": "p. 40",
          "body": "This triple gathers Hannah Ott's three self-portrait portfolios: YEAR OF TUESDAYS (the weekly chair, year one), YEAR OF SUNDAYS (the morning kitchen, year two), and YEAR OF FRIDAYS (the evening doorway, year three). The three series, taken together, present a continuous self-portrait spanning a hundred and fifty-six weeks, on three different days of the week. The triple is sequenced by year, and Ott has, in the introductory note, indicated that the project will close at the end of year four.",
          "infobox": {
            "Photographer": "Hannah Ott",
            "Series 1": "Year of Tuesdays · 2022",
            "Series 2": "Year of Sundays · 2023",
            "Series 3": "Year of Fridays · 2024",
            "Format": "Medium format, 6×6",
            "Edition": "Editions of 30",
            "Print": "Pigment on cotton"
          }
        }
      ],
      "content_theme": {
        "primary": "dedicated",
        "mode": "dedicated_per_template"
      }
