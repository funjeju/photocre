        {
          "eyebrow": "— ON LOOKING",
          "pullquote": "In every walk with nature one receives far more than he seeks.",
          "byline": "JOHN MUIR · 1838–1914",
          "caption": "Sierra Nevada, snowfields above Tuolumne, June 1873.",
          "folio": "p. 14"
        },
        {
          "eyebrow": "— ON PATIENCE",
          "pullquote": "Not until we are lost do we begin to understand ourselves.",
          "byline": "HENRY DAVID THOREAU · 1817–1862",
          "caption": "Walden Pond, the second autumn, north shore.",
          "folio": "p. 22"
