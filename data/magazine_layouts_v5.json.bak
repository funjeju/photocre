      "dedicated_sets": [
        {
          "eyebrow": "— THREE-CHAPTER INDEX",
          "title": "Memoirs in Three Seasons — the working draft of a forthcoming book of three connected essays.",
          "script": "Memoirs",
          "folio": "p. 04",
          "infobox": {
            "Chapter I": "Spring · The First Apartment — pp. 4 to 38, twenty-eight working photographs of the early flat in Brussels, where most of these essays were drafted between February and the following May.",
            "Chapter II": "Summer · The Studio Years — pp. 39 to 84, forty-six photographs from the four working summers in the south of France, including the unpublished material from the Avignon period.",
            "Chapter III": "Autumn · The Long Return — pp. 85 to 132, thirty-nine photographs from the eight months of travel that close the volume, including the working notes from the Berlin and Trieste residencies.",
            "Notes": "All three chapters are illustrated with previously unpublished archival material. The publisher has agreed to print the volume in a single edition of one thousand."
          }
        },
        {
          "eyebrow": "— THREE-PART INDEX",
          "title": "A Year Abroad — the working table of contents for the third volume of the published travel notes.",
          "script": "Notes",
          "folio": "p. 12",
          "infobox": {
            "Part I": "The Northern Months — pp. 4 to 56, thirty-six entries from the working winter, including the long Helsinki essay and the abandoned Tallinn material from late January.",
            "Part II": "The Mediterranean Spring — pp. 57 to 124, forty-two entries from the working spring, the Marseille and Genoa pieces, and the Sicilian field notes published in shorter form last year.",
            "Part III": "The Eastern Summer — pp. 125 to 188, thirty-one entries from the working summer, the Bucharest residency, the Black Sea coast, and the unpublished Trabzon journal in its entirety.",
            "Editor": "M. K. Lyngård, copy-editing by the publisher's editorial board, with the working notes preserved in the archive."
          }
        },
        {
          "eyebrow": "— THREE-CHAPTER INDEX",
          "title": "War and Peace — the working journal of a long correspondence between two friends.",
          "script": "Letters",
          "folio": "p. 20",
          "infobox": {
            "Chapter I": "The Early Letters — pp. 4 to 62, forty-eight letters covering the working period from the first meeting in 1976 through the end of the corresponding year, with the photographs that accompanied them.",
            "Chapter II": "The Middle Years — pp. 63 to 154, ninety-two letters from the long working period of professional correspondence, including the unpublished material from the second author's archive.",
            "Chapter III": "The Later Letters — pp. 155 to 218, thirty-eight letters from the closing four years of the correspondence, with the editorial notes by the surviving author and a short closing essay.",
            "Provenance": "All letters held in the literary archive of the senior university library. Photographs reproduced with permission of the corresponding estate."
          }
        },
        {
          "eyebrow": "— THREE-CHAPTER INDEX",
          "title": "The Lighthouse Keeper — a posthumous edition of the diaries kept across forty years of service.",
          "script": "Diaries",
          "folio": "p. 28",
          "infobox": {
            "Volume I": "The Apprentice Years — pp. 4 to 92, the early diaries from the first three lighthouses, with editorial notes on the working conditions of the Hebridean stations of the period.",
            "Volume II": "The Working Decades — pp. 93 to 218, the long working period at the Cape Wrath station, including the celebrated weather logs and the unpublished correspondence with the meteorological office.",
            "Volume III": "The Final Watch — pp. 219 to 284, the last six years at the Bell Rock station, before automation, including the diary entries from the night of the keeper's farewell ceremony.",
            "Editor": "H. Drummond, with archival assistance from the Northern Lighthouse Board, working in collaboration with the family."
          }
        },
        {
          "eyebrow": "— THREE-PART INDEX",
          "title": "The Cookery Years — a working memoir from the kitchen, in three sequential volumes.",
          "script": "Recipes",
          "folio": "p. 36",
          "infobox": {
            "Volume I": "The Family Kitchen — pp. 4 to 78, the first sixty recipes, drawn from the family kitchen of the working author, with photographs of the original handwritten notebooks held in the family archive.",
            "Volume II": "The Restaurant Years — pp. 79 to 162, the working recipes from the seven restaurant kitchens of the author's professional career, with photographs from the working line.",
            "Volume III": "The Retired Kitchen — pp. 163 to 224, the recent recipes of the author's retirement, simpler and slower than the earlier work, with portraits of the suppliers who made them possible.",
            "Foreword": "Written by the editor in collaboration with the author, in the kitchen of the third volume's photographs."
          }
        },
        {
          "eyebrow": "— THREE-CHAPTER INDEX",
          "title": "The Garden Diaries — three decades of weekly entries from a single small London garden.",
          "script": "Garden",
          "folio": "p. 44",
          "infobox": {
            "Decade I": "The First Ten Years — pp. 4 to 86, the working diaries from the first decade of garden ownership, including the early planting decisions and the first major redesign of the working year.",
            "Decade II": "The Mature Garden — pp. 87 to 174, the long middle period in which the garden settled into its present form, with photographs from the second redesign and the addition of the hothouse extension.",
            "Decade III": "The Late Garden — pp. 175 to 248, the recent diaries of the garden's quieter phase, including the working notes from the seasons after the author's retirement and the final planting decisions.",
            "Photographs": "All photographs by the author, made on a single 35mm camera kept in the garden shed for the working period."
          }
        },
        {
          "eyebrow": "— THREE-PART INDEX",
          "title": "The Walking Notes — three published volumes of the long-distance walking journals of the working author.",
          "script": "Walking",
          "folio": "p. 52",
          "infobox": {
            "Volume I": "Coast to Coast — pp. 4 to 64, the first long walk, from the working west coast to the working east coast, with the field journals and the corresponding maps.",
            "Volume II": "The Long Trail — pp. 65 to 142, the second long walk, southward through the working spine of the country, with the photographs from the eleven walking weeks.",
            "Volume III": "The Last Walk — pp. 143 to 198, the closing walk of the trilogy, on the smaller and more private routes of the author's home county, written in the working autumn.",
            "Cartography": "All maps drawn by the author, in field conditions, with the original folded sheets reproduced in the appendix."
          }
        },
        {
          "eyebrow": "— THREE-CHAPTER INDEX",
          "title": "Conservatory — published correspondence of a lifelong botanical gardener.",
          "script": "Plants",
          "folio": "p. 60",
          "infobox": {
            "Correspondence I": "The Eastern Letters — pp. 4 to 88, the long working exchange with the Tokyo botanical garden's director, on the cultivation of temperate species in the working tropics, across a working twenty-two years.",
            "Correspondence II": "The Western Letters — pp. 89 to 174, the parallel exchange with the Vancouver garden's working director, on Pacific Northwest species and the corresponding climate considerations.",
            "Correspondence III": "The Southern Letters — pp. 175 to 248, the brief but consequential exchange with the Cape Town garden's working director, on the cultivation challenges of the working Cape flora.",
            "Index": "A working index of plant species, in three languages, is included as an appendix to the volume."
          }
        },
        {
          "eyebrow": "— THREE-PART INDEX",
          "title": "The Conductor — a biography in three working acts of the late conductor of the city orchestra.",
          "script": "Music",
          "folio": "p. 68",
          "infobox": {
            "Act I": "The Early Years — pp. 4 to 96, the working biography of the conductor's apprenticeship, the first conducting positions, and the early professional years before the appointment to the city orchestra.",
            "Act II": "The Working Decades — pp. 97 to 218, the long working period of the conductor's tenure, including the published correspondence with the working composers and the major working recordings of the period.",
            "Act III": "The Closing Years — pp. 219 to 284, the working final period of the conductor's life, including the retirement years and the working correspondence with the chosen successor at the orchestra.",
            "Appendix": "A complete list of the conductor's working repertoire, by year, with the corresponding venues and orchestras."
          }
        },
        {
          "eyebrow": "— THREE-CHAPTER INDEX",
          "title": "After Practice — the working memoirs of a retired anaesthesiologist, in three connected volumes.",
          "script": "Practice",
          "folio": "p. 76",
          "infobox": {
            "Volume I": "The Training Years — pp. 4 to 78, the working biography of the author's medical school years and the early specialist training, with photographs from the working hospitals of the period.",
            "Volume II": "The Working Career — pp. 79 to 168, the long working period of the author's hospital practice, including the unpublished case notes from the major working hospitals of the working career.",
            "Volume III": "After Retirement — pp. 169 to 224, the working closing volume of the trilogy, on the working life after retirement, the working teaching commitments, and the working family.",
            "Photographs": "All photographs by the author's working spouse, on a single working camera kept in the family kitchen."
          }
        }
      ],
      "content_theme": {
        "primary": "dedicated",
        "mode": "dedicated_per_template"
      }
    },
