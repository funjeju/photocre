      "dedicated_sets": [
        {
          "label": "ROME",
          "caption": "Founded by tradition in 753 BCE; pop. 2.87m; seven hills; eleven aqueducts of which two are still functional.",
          "caption_2": "Photographed at the Spanish Steps, the third Tuesday of October, the second espresso of the morning.",
          "folio": "p. 06"
        },
        {
          "label": "TOKYO",
          "caption": "Largest metropolitan area on Earth; pop. 37.4m; thirteen rail operators; one earthquake every three minutes, on average.",
