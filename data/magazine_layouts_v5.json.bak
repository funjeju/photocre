      "dedicated_sets": [
        {
          "eyebrow": "— ISSUE 04 · CUT-UP & CARRY ON · TYPE / SOUND / SPEED",
          "title": "STREET TYPE",
          "kicker": "Hand-painted shop signs, found alphabets, six cities of people who never asked anyone's permission to letter their own walls.",
          "folio": "p. 02"
        },
        {
          "eyebrow": "— ISSUE 04 · TWO-CHANNEL · LOUD / QUIET",
          "title": "CUTUP",
          "kicker": "A collage method that goes back further than William Burroughs and forward further than the next zine you'll see at the bookstall on Saturday.",
          "folio": "p. 06"
        },
        {
          "eyebrow": "— ISSUE 04 · OUTSIDE THE TRACK · DUB / DRONE",
          "title": "SOUND TEST",
          "kicker": "Tape echoes, broken speakers, the music made when the equipment cooperates and the music made when it gives up entirely.",
          "folio": "p. 10"
        },
        {
          "eyebrow": "— ISSUE 04 · TILE & TIDE · GRID / FRAY",
          "title": "PATTERN PLAY",
          "kicker": "What happens when a strict grid finally meets a piece of fabric that has been washed too many times. Order, eventually, learns to behave.",
          "folio": "p. 14"
        },
        {
          "eyebrow": "— ISSUE 04 · ALL THIS WEEK · DEADLINE / RUSH",
          "title": "FAST WORK",
          "kicker": "Posters made over three nights for a show that opens on Friday — the printing costs more than any of us are getting paid.",
          "folio": "p. 18"
        },
        {
          "eyebrow": "— ISSUE 04 · OUT OF SHAPE · STRUCTURE / BREAK",
          "title": "BREAK FORM",
          "kicker": "What you do once the rules of composition stop helping you. Notes from a conversation that has gone on too long, between paint and paper.",
          "folio": "p. 22"
        },
        {
          "eyebrow": "— ISSUE 04 · IN PARALLEL · OPEN / FOLD",
          "title": "LOUD AND QUIET",
          "kicker": "Two pages, two volumes, one bind. The book that argues with itself between the gutter and the front cover, until the last spread.",
          "folio": "p. 26"
        },
        {
          "eyebrow": "— ISSUE 04 · COUNTER · METRONOME / DRIFT",
          "title": "TWO TEMPOS",
          "kicker": "A printed conversation between a designer who works fast and a typographer who, on principle, refuses to be hurried by anyone, ever.",
          "folio": "p. 30"
        },
        {
          "eyebrow": "— ISSUE 04 · CORNERED · HARD / SOFT",
          "title": "SHARP EDGES",
          "kicker": "Knife-cut paper, hot-foil press, the typography that prefers to draw blood over coddling its readers' weekend mornings.",
          "folio": "p. 34"
        },
        {
          "eyebrow": "— ISSUE 04 · UNFINISHED · DRAFT / ROUGH",
          "title": "RAW MATERIAL",
          "kicker": "A spread of working sketches, contact sheets, stray annotations — none of which were ever supposed to be published. Until now.",
          "folio": "p. 38"
        }
      ],
      "content_theme": {
        "primary": "dedicated",
        "mode": "dedicated_per_template"
      }
    },
